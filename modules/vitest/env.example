# A separate Neon branch's pooled connection URL used ONLY by the
# integration test project. Create the branch via the Neon Console
# (your project → Branches → New branch, call it `test`), then copy
# its **pooled** connection string here. The branch is reused across
# CI runs; tests must clean up after themselves via the
# `withRolledBackTx` helper so successive runs don't see stale data.
#
# Required by:
#   - `npm run test:integration` (local + CI `integration` job)
# Not used by:
#   - `npm test` / `npm run test:unit` (unit-only — uses defaults)
#   - `npm run dev` / `npm run build` (use DATABASE_URL instead)
DATABASE_URL_TEST="postgresql://..."
